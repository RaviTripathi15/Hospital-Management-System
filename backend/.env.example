# ─────────────────────────────────────────────
# Server Configuration
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ─────────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────────
MONGO_URI=mongodb+srv://tripathiravi5500_db_user:ZroZpIVBRacRSifo@cluster0.lfoqbqo.mongodb.net/health_platform?appName=Cluster0
MONGO_URI_PROD=mongodb+srv://tripathiravi5500_db_user:ZroZpIVBRacRSifo@cluster0.lfoqbqo.mongodb.net/health_platform?appName=Cluster0

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_SECRET=your_refresh_token_secret_change_in_production
JWT_REFRESH_EXPIRE=7d

# ─────────────────────────────────────────────
# Email (SMTP)
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Health Platform <noreply@healthplatform.gov>

# ─────────────────────────────────────────────
# File Uploads
# ─────────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# ─────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

# ─────────────────────────────────────────────
# App Settings
# ─────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
PAGINATION_DEFAULT_LIMIT=10
PAGINATION_MAX_LIMIT=100
LOW_STOCK_THRESHOLD_DAYS=30
EXPIRY_ALERT_DAYS=90
