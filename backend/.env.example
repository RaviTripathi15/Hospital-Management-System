# ═══════════════════════════════════════════════════════════════
#  Health Platform Backend — Environment Variables
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# Server
# ───────────────────────────────────────────────────────────────
# Set to 'production' on Render; leave as 'development' locally
NODE_ENV=development

# Render injects PORT automatically — do NOT hard-code in production
PORT=5000

# The publicly reachable URL of your FRONTEND on Render
# e.g. https://health-platform-frontend.onrender.com
# This is used to build the CORS whitelist.
# Multiple URLs can be comma-separated:
#   CLIENT_URL=https://app.onrender.com,https://mycustomdomain.com
CLIENT_URL=http://localhost:3000

# ───────────────────────────────────────────────────────────────
# MongoDB Atlas
# ───────────────────────────────────────────────────────────────
# Used in development / staging
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.example.net/health_platform?appName=Cluster0
# Used when NODE_ENV=production
MONGO_URI_PROD=mongodb+srv://<user>:<password>@cluster0.example.net/health_platform?appName=Cluster0

# ───────────────────────────────────────────────────────────────
# JWT  (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
# ───────────────────────────────────────────────────────────────
JWT_SECRET=<generate_strong_random_64_char_hex>
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_SECRET=<generate_another_strong_random_64_char_hex>
JWT_REFRESH_EXPIRE=7d

# ───────────────────────────────────────────────────────────────
# Email (SMTP)
# ───────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
# For Gmail use an App Password (not your regular password)
SMTP_PASS=your_16_char_app_password
EMAIL_FROM=Health Platform <noreply@healthplatform.gov>

# ───────────────────────────────────────────────────────────────
# File Uploads
# ───────────────────────────────────────────────────────────────
UPLOAD_PATH=./uploads
# 5 MB in bytes
MAX_FILE_SIZE=5242880

# ───────────────────────────────────────────────────────────────
# Rate Limiting
# ───────────────────────────────────────────────────────────────
# Window in milliseconds (900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000
# Max requests per window for general API
RATE_LIMIT_MAX=100
# Max auth attempts per window
AUTH_RATE_LIMIT_MAX=10

# ───────────────────────────────────────────────────────────────
# Logging
# ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
# On Render the filesystem is ephemeral; logs are also streamed to stdout
LOG_DIR=./logs

# ───────────────────────────────────────────────────────────────
# Application
# ───────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
PAGINATION_DEFAULT_LIMIT=10
PAGINATION_MAX_LIMIT=100
LOW_STOCK_THRESHOLD_DAYS=30
EXPIRY_ALERT_DAYS=90

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
