# ─────────────────────────────────────────────────────────────────────────────
#  Frontend Environment Variables
#  Copy this to .env and fill in values.
#  VITE_ prefix is REQUIRED for Vite to expose vars to the browser bundle.
# ─────────────────────────────────────────────────────────────────────────────

# Full URL to the backend REST API (no trailing slash)
# Local dev  : http://localhost:5000/api/v1
# Production : https://<your-backend-service>.onrender.com/api/v1
VITE_API_URL=http://localhost:5000/api/v1

# Full URL to the backend server for Socket.io  (no trailing slash, no path)
# Local dev  : http://localhost:5000
# Production : https://<your-backend-service>.onrender.com
VITE_SOCKET_URL=http://localhost:5000

# App metadata (optional, shown in UI)
VITE_APP_NAME=HealthCare Platform
VITE_APP_VERSION=1.0.0
